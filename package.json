{
  "name": "boilerplate-nestjs-swc",
  "description": "Nest.js boilerplate lightweight",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "eslint . --ignore-pattern \"node_modules\" --ignore-pattern \"dist\" --config eslint.config.js",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci",
    "test:watch": "jest --passWithNoTests --watch",
    "test:watchAll": "jest --passWithNoTests --watchAll",
    "test:coverage": "jest --passWithNoTests --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.1.5",
    "@scalar/nestjs-api-reference": "^0.4.11",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.25.1",
    "@faker-js/faker": "^9.7.0",
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.0",
    "@swc/cli": "^0.7.3",
    "@swc/core": "^1.11.22",
    "@swc/jest": "^0.2.38",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "lint-staged": "^15.5.1",
    "msw": "^2.7.5",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "typescript": "^5.8.3"
  },
  "license": "UNLICENSED"
}
