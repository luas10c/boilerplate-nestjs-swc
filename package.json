{
  "name": "boilerplate-nestjs-swc",
  "description": "Nest.js boilerplate lightweight",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "build": "nest build",
    "lint": "eslint . --cache",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci",
    "test:watch": "jest --passWithNoTests --watch",
    "test:watchAll": "jest --passWithNoTests --watchAll",
    "test:coverage": "jest --passWithNoTests --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@scalar/nestjs-api-reference": "^1.1.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@jest/globals": "^30.3.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "@swc/jest": "^0.2.39",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-mock-extended": "4.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.6",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "license": "UNLICENSED"
}
