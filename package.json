{
  "name": "boilerplate-nestjs-swc",
  "description": "Nest.js boilerplate lightweight",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "eslint . --ignore-pattern \"node_modules\" --ignore-pattern \"dist\" --config eslint.config.js",
    "prepare": "husky",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --passWithNoTests --watch",
    "test:ci": "jest --passWithNoTests --ci",
    "test:coverage": "jest --passWithNoTests --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@nestjs/platform-express": "^11.0.12",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.23.0",
    "@faker-js/faker": "^9.6.0",
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/testing": "^11.0.12",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.13",
    "@swc/jest": "^0.2.37",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "lint-staged": "^15.5.0",
    "msw": "^2.7.3",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "typescript": "^5.8.2"
  },
  "license": "UNLICENSED"
}
